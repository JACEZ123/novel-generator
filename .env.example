# 复制为 .env 或直接在环境里注入。环境变量优先级高于 data/config.json。
# 模型 API Key（必填其一）
JACE_API_KEY=
# 兼容变量名（二选一即可）
# OPENAI_API_KEY=

# OpenAI 兼容接口地址（默认 DeepSeek；换任意兼容服务改这里）
JACE_BASE_URL=https://api.deepseek.com

# 默认快模型（正文/审查等阶段）
JACE_MODEL=deepseek-v4-flash
# 默认强模型（大纲/审计/修订等阶段）
JACE_MODEL_STRONG=deepseek-v4-pro

# 服务端口（默认 4568）
JACE_PORT=4568
